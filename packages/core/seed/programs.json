      {
        "weekCount": 4,
        "progressionRule": "linear",
        "linearStepKg": 2.5,
        "targetRIR": 0,
        "weeks": [
          {
            "isDeload": false,
            "days": [
              { "dayIndex": 1, "name": "Den A1", "exercises": [
                { "key": "exercise.bench_press",            "sets": 3, "repsMin": 5, "repsMax": 5,  "rest": 180 },
                { "key": "exercise.back_squat",             "sets": 3, "repsMin": 5, "repsMax": 5,  "rest": 180 },
                { "key": "exercise.dumbbell_curl",          "sets": 2, "repsMin": 8, "repsMax": 12, "rest": 75  }
              ]},
              { "dayIndex": 2, "name": "Den B1", "exercises": [
