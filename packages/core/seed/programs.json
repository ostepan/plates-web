[
  {
    "name": "Push Pull Legs",
    "author": "Plates",
    "weeks": 4,
    "notes": "Klasické 6denní PPL s vestavěným odlehčovacím týdnem. Dvojitá progrese na všech pracovních sériích.",
    "mesocycles": [
      {
        "weekCount": 4,
        "progressionRule": "doubleProgression",
        "linearStepKg": 2.5,
        "targetRIR": 2,
        "weeks": [
          {
            "isDeload": false,
            "days": [
              { "dayIndex": 1, "name": "Tlak A",  "exercises": [
                { "key": "exercise.bench_press",            "sets": 3, "repsMin": 6, "repsMax": 8,  "rest": 150 },
                { "key": "exercise.overhead_press",         "sets": 3, "repsMin": 8, "repsMax": 10, "rest": 120 },
                { "key": "exercise.incline_bench_press",    "sets": 3, "repsMin": 8, "repsMax": 12, "rest": 120 },
                { "key": "exercise.lateral_raise",          "sets": 3, "repsMin": 12,"repsMax": 15, "rest": 60  },
                { "key": "exercise.tricep_pushdown",        "sets": 3, "repsMin": 10,"repsMax": 15, "rest": 75  }
              ]},
              { "dayIndex": 2, "name": "Tah A",  "exercises": [
                { "key": "exercise.deadlift",               "sets": 3, "repsMin": 4, "repsMax": 6,  "rest": 180 },
                { "key": "exercise.pullup",                 "sets": 3, "repsMin": 6, "repsMax": 10, "rest": 120 },
                { "key": "exercise.barbell_row",            "sets": 3, "repsMin": 8, "repsMax": 10, "rest": 120 },
                { "key": "exercise.face_pull",              "sets": 3, "repsMin": 12,"repsMax": 15, "rest": 60  },
                { "key": "exercise.barbell_curl",           "sets": 3, "repsMin": 8, "repsMax": 12, "rest": 75  }
              ]},
              { "dayIndex": 3, "name": "Nohy A",  "exercises": [
                { "key": "exercise.back_squat",             "sets": 3, "repsMin": 6, "repsMax": 8,  "rest": 180 },
                { "key": "exercise.romanian_deadlift",      "sets": 3, "repsMin": 8, "repsMax": 10, "rest": 150 },
                { "key": "exercise.leg_press",              "sets": 3, "repsMin": 10,"repsMax": 12, "rest": 120 },
                { "key": "exercise.leg_curl",               "sets": 3, "repsMin": 10,"repsMax": 15, "rest": 75  },
                { "key": "exercise.calf_raise",             "sets": 4, "repsMin": 10,"repsMax": 15, "rest": 60  }
              ]},
              { "dayIndex": 4, "name": "Tlak B",  "exercises": [
                { "key": "exercise.incline_bench_press",    "sets": 3, "repsMin": 6, "repsMax": 8,  "rest": 150 },
                { "key": "exercise.dumbbell_shoulder_press","sets": 3, "repsMin": 8, "repsMax": 10, "rest": 120 },
                { "key": "exercise.dips",                   "sets": 3, "repsMin": 8, "repsMax": 12, "rest": 120 },
                { "key": "exercise.cable_crossover",        "sets": 3, "repsMin": 12,"repsMax": 15, "rest": 60  },
                { "key": "exercise.skullcrusher",           "sets": 3, "repsMin": 10,"repsMax": 12, "rest": 75  }
              ]},
              { "dayIndex": 5, "name": "Tah B",  "exercises": [
                { "key": "exercise.barbell_row",            "sets": 3, "repsMin": 6, "repsMax": 8,  "rest": 150 },
                { "key": "exercise.lat_pulldown",           "sets": 3, "repsMin": 8, "repsMax": 12, "rest": 90  },
                { "key": "exercise.cable_row",              "sets": 3, "repsMin": 10,"repsMax": 12, "rest": 90  },
                { "key": "exercise.face_pull",              "sets": 3, "repsMin": 12,"repsMax": 15, "rest": 60  },
                { "key": "exercise.hammer_curl",            "sets": 3, "repsMin": 10,"repsMax": 12, "rest": 75  }
              ]},
              { "dayIndex": 6, "name": "Nohy B",  "exercises": [
                { "key": "exercise.romanian_deadlift",      "sets": 3, "repsMin": 6, "repsMax": 8,  "rest": 150 },
                { "key": "exercise.bulgarian_split_squat",  "sets": 3, "repsMin": 8, "repsMax": 10, "rest": 90  },
                { "key": "exercise.leg_press",              "sets": 3, "repsMin": 10,"repsMax": 15, "rest": 90  },
                { "key": "exercise.leg_extension",          "sets": 3, "repsMin": 10,"repsMax": 15, "rest": 60  },
                { "key": "exercise.calf_raise",             "sets": 4, "repsMin": 10,"repsMax": 15, "rest": 60  }
              ]}
            ]
          },
          { "isDeload": false, "copyOfWeek": 0 },
          { "isDeload": false, "copyOfWeek": 0 },
          { "isDeload": true,  "copyOfWeek": 0, "deloadVolumePercent": 60, "deloadIntensityPercent": 75 }
        ]
      }
    ]
  },

  {
    "name": "Upper / Lower",
    "author": "Plates",
    "weeks": 4,
    "notes": "4denní rozdělení horní/dolní. Progrese podle RIR — přidej váhu, když trénink dokončíš s větší rezervou, než je cílové RIR.",
    "mesocycles": [
      {
        "weekCount": 4,
        "progressionRule": "rirBased",
        "linearStepKg": 2.5,
        "targetRIR": 2,
        "weeks": [
          {
            "isDeload": false,
            "days": [
              { "dayIndex": 1, "name": "Horní A", "exercises": [
                { "key": "exercise.bench_press",            "sets": 4, "repsMin": 6,  "repsMax": 8,  "rest": 150 },
                { "key": "exercise.barbell_row",            "sets": 4, "repsMin": 6,  "repsMax": 8,  "rest": 150 },
                { "key": "exercise.dumbbell_shoulder_press","sets": 3, "repsMin": 8,  "repsMax": 12, "rest": 120 },
                { "key": "exercise.lat_pulldown",           "sets": 3, "repsMin": 10, "repsMax": 12, "rest": 90  },
                { "key": "exercise.barbell_curl",           "sets": 3, "repsMin": 8,  "repsMax": 12, "rest": 75  },
                { "key": "exercise.tricep_pushdown",        "sets": 3, "repsMin": 10, "repsMax": 15, "rest": 75  }
              ]},
              { "dayIndex": 2, "name": "Dolní A", "exercises": [
                { "key": "exercise.back_squat",             "sets": 4, "repsMin": 5,  "repsMax": 8,  "rest": 180 },
                { "key": "exercise.romanian_deadlift",      "sets": 3, "repsMin": 8,  "repsMax": 10, "rest": 150 },
                { "key": "exercise.leg_press",              "sets": 3, "repsMin": 10, "repsMax": 12, "rest": 120 },
                { "key": "exercise.leg_curl",               "sets": 3, "repsMin": 10, "repsMax": 15, "rest": 75  },
                { "key": "exercise.calf_raise",             "sets": 4, "repsMin": 10, "repsMax": 15, "rest": 60  }
              ]},
              { "dayIndex": 3, "name": "Horní B", "exercises": [
                { "key": "exercise.incline_bench_press",    "sets": 4, "repsMin": 8,  "repsMax": 10, "rest": 120 },
                { "key": "exercise.cable_row",              "sets": 4, "repsMin": 8,  "repsMax": 10, "rest": 120 },
                { "key": "exercise.lateral_raise",          "sets": 4, "repsMin": 12, "repsMax": 15, "rest": 60  },
                { "key": "exercise.face_pull",              "sets": 3, "repsMin": 12, "repsMax": 15, "rest": 60  },
                { "key": "exercise.hammer_curl",            "sets": 3, "repsMin": 10, "repsMax": 12, "rest": 75  },
                { "key": "exercise.skullcrusher",           "sets": 3, "repsMin": 8,  "repsMax": 12, "rest": 75  }
              ]},
              { "dayIndex": 4, "name": "Dolní B", "exercises": [
                { "key": "exercise.deadlift",               "sets": 3, "repsMin": 4,  "repsMax": 6,  "rest": 180 },
                { "key": "exercise.bulgarian_split_squat",  "sets": 3, "repsMin": 8,  "repsMax": 10, "rest": 120 },
                { "key": "exercise.hip_thrust",             "sets": 3, "repsMin": 8,  "repsMax": 12, "rest": 120 },
                { "key": "exercise.leg_extension",          "sets": 3, "repsMin": 12, "repsMax": 15, "rest": 60  },
                { "key": "exercise.calf_raise",             "sets": 4, "repsMin": 10, "repsMax": 15, "rest": 60  }
              ]}
            ]
          },
          { "isDeload": false, "copyOfWeek": 0 },
          { "isDeload": false, "copyOfWeek": 0 },
          { "isDeload": true,  "copyOfWeek": 0, "deloadVolumePercent": 60, "deloadIntensityPercent": 70 }
        ]
      }
    ]
  },

  {
    "name": "5/3/1 BBB",
    "author": "Jim Wendler",
    "weeks": 4,
    "notes": "5/3/1 Boring But Big — hlavní cviky podle procenta z 1RM, doplňky lineární progresí. 4. týden je automatické odlehčení.",
    "mesocycles": [
      {
        "weekCount": 4,
        "progressionRule": "percentageOf1RM",
        "linearStepKg": 2.5,
        "targetRIR": 1,
        "weeks": [
          {
            "isDeload": false,
            "days": [
              { "dayIndex": 1, "name": "Den tlaku", "exercises": [
                { "key": "exercise.overhead_press",         "sets": 5, "repsMin": 5, "repsMax": 5,  "rest": 180 },
                { "key": "exercise.bench_press",            "sets": 5, "repsMin": 10,"repsMax": 10, "rest": 120 },
                { "key": "exercise.chinup",                 "sets": 5, "repsMin": 10,"repsMax": 10, "rest": 90  }
              ]},
              { "dayIndex": 2, "name": "Den dřepu", "exercises": [
                { "key": "exercise.back_squat",             "sets": 5, "repsMin": 5, "repsMax": 5,  "rest": 180 },
                { "key": "exercise.back_squat",             "sets": 5, "repsMin": 10,"repsMax": 10, "rest": 120 },
                { "key": "exercise.leg_curl",               "sets": 5, "repsMin": 10,"repsMax": 15, "rest": 60  }
              ]},
              { "dayIndex": 3, "name": "Den benche", "exercises": [
                { "key": "exercise.bench_press",            "sets": 5, "repsMin": 5, "repsMax": 5,  "rest": 180 },
                { "key": "exercise.overhead_press",         "sets": 5, "repsMin": 10,"repsMax": 10, "rest": 120 },
                { "key": "exercise.barbell_row",            "sets": 5, "repsMin": 10,"repsMax": 10, "rest": 90  }
              ]},
              { "dayIndex": 4, "name": "Den mrtvého tahu", "exercises": [
                { "key": "exercise.deadlift",               "sets": 5, "repsMin": 5, "repsMax": 5,  "rest": 180 },
                { "key": "exercise.deadlift",               "sets": 5, "repsMin": 10,"repsMax": 10, "rest": 150 },
                { "key": "exercise.hyperextension",         "sets": 5, "repsMin": 10,"repsMax": 15, "rest": 60  }
              ]}
            ]
          },
          { "isDeload": false, "copyOfWeek": 0 },
          { "isDeload": false, "copyOfWeek": 0 },
          { "isDeload": true,  "copyOfWeek": 0, "deloadVolumePercent": 50, "deloadIntensityPercent": 65 }
        ]
      }
    ]
  },

  {
