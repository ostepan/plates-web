  {
    "name": "GZCLP",
    "author": "Cody Lefever",
    "weeks": 4,
    "notes": "GZCL lineární progrese — 4denní rotace (tlak, dřep, bench, mrtvý tah) se třemi úrovněmi: T1 těžká 5×3, T2 hypertrofie 3×10, T3 doplňky 3×15. Lineární přidávání váhy každý trénink.",
    "mesocycles": [
      {
        "weekCount": 4,
        "progressionRule": "linear",
        "linearStepKg": 2.5,
        "targetRIR": 1,
        "weeks": [
          {
            "isDeload": false,
            "days": [
              { "dayIndex": 1, "name": "Den tlaku", "exercises": [
                { "key": "exercise.overhead_press",         "sets": 5, "repsMin": 3,  "repsMax": 3,  "rest": 180 },
                { "key": "exercise.bench_press",            "sets": 3, "repsMin": 10, "repsMax": 10, "rest": 120 },
                { "key": "exercise.lat_pulldown",           "sets": 3, "repsMin": 15, "repsMax": 15, "rest": 90  }
              ]},
              { "dayIndex": 2, "name": "Den dřepu", "exercises": [
                { "key": "exercise.back_squat",             "sets": 5, "repsMin": 3,  "repsMax": 3,  "rest": 180 },
                { "key": "exercise.romanian_deadlift",      "sets": 3, "repsMin": 10, "repsMax": 10, "rest": 150 },
                { "key": "exercise.leg_curl",               "sets": 3, "repsMin": 15, "repsMax": 15, "rest": 75  }
              ]},
              { "dayIndex": 3, "name": "Den benche", "exercises": [
                { "key": "exercise.bench_press",            "sets": 5, "repsMin": 3,  "repsMax": 3,  "rest": 180 },
                { "key": "exercise.overhead_press",         "sets": 3, "repsMin": 10, "repsMax": 10, "rest": 120 },
                { "key": "exercise.cable_row",              "sets": 3, "repsMin": 15, "repsMax": 15, "rest": 90  }
              ]},
              { "dayIndex": 4, "name": "Den mrtvého tahu", "exercises": [
                { "key": "exercise.deadlift",               "sets": 5, "repsMin": 3,  "repsMax": 3,  "rest": 180 },
                { "key": "exercise.back_squat",             "sets": 3, "repsMin": 10, "repsMax": 10, "rest": 150 },
                { "key": "exercise.hyperextension",         "sets": 3, "repsMin": 15, "repsMax": 15, "rest": 60  }
              ]}
            ]
          },
          { "isDeload": false, "copyOfWeek": 0 },
          { "isDeload": false, "copyOfWeek": 0 },
          { "isDeload": true,  "copyOfWeek": 0, "deloadVolumePercent": 60, "deloadIntensityPercent": 70 }
        ]
      }
    ]
